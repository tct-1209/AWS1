        <mxCell id="71" value="Backend tạo URL VNPay, nhận redirect/callback và cập nhật trạng thái đơn hàng." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Arial;fontSize=13;fontColor=#1f2937;" vertex="1" parent="1">
