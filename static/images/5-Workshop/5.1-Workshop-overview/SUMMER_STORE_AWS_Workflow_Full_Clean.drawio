        </mxCell>
        <mxCell id="74" value="Không thêm CloudFront, Route 53, Lambda hoặc API Gateway vì hiện dự án đang chạy trực tiếp bằng S3 Static Website + EC2 Elastic IP + RDS. IAM, AWS CLI, CloudWatch và AWS Budgets là nhóm hỗ trợ vận hành/quản trị, không phải luồng request chính của người dùng." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Arial;fontSize=15;fontColor=#64748b;" vertex="1" parent="1">
